From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: huangcm <1263938474@qq.com>
Date: Sat, 21 Jun 2025 15:37:39 +0800
Subject: panel-simple: gt9xx: fix tp power from panel power

---
 drivers/gpu/drm/panel/panel-simple.c | 37 ++++++
 drivers/input/touchscreen/goodix.c   | 57 +++++++++-
 drivers/input/touchscreen/goodix.h   |  3 +
 include/drm/drm_panel.h              | 13 +++
 4 files changed, 108 insertions(+), 2 deletions(-)

diff --git a/drivers/gpu/drm/panel/panel-simple.c b/drivers/gpu/drm/panel/panel-simple.c
index 111111111111..222222222222 100644
--- a/drivers/gpu/drm/panel/panel-simple.c
+++ b/drivers/gpu/drm/panel/panel-simple.c
@@ -32,6 +32,9 @@
 #include <linux/regulator/consumer.h>
 #include <linux/spi/spi.h>
 #include <linux/rockchip-panel-notifier.h>
+#include <linux/init.h>
+#include <linux/device.h>
+#include <linux/notifier.h>
 
 #include <video/display_timing.h>
 #include <video/mipi_display.h>
@@ -486,6 +489,34 @@ static int panel_simple_get_non_edid_modes(struct panel_simple *panel,
 	return num;
 }
 
+static BLOCKING_NOTIFIER_HEAD(panel_simple_notifier_list);
+
+static int panel_simple_send_notify(int state, void *data)
+{
+    struct panel_simple_notify_data ndata;
+    
+    ndata.power_state = state;
+    ndata.private_data = data;
+    
+    pr_err("%s, %d", __func__, __LINE__);
+    return blocking_notifier_call_chain(&panel_simple_notifier_list, 
+                                      state, &ndata);
+}
+
+int panel_simple_register_notifier(struct notifier_block *nb)
+{
+    pr_err("%s, %d", __func__, __LINE__);
+    return blocking_notifier_chain_register(&panel_simple_notifier_list, nb);
+}
+EXPORT_SYMBOL_GPL(panel_simple_register_notifier);
+
+int panel_simple_unregister_notifier(struct notifier_block *nb)
+{
+    pr_err("%s, %d", __func__, __LINE__);
+    return blocking_notifier_chain_unregister(&panel_simple_notifier_list, nb);
+}
+EXPORT_SYMBOL_GPL(panel_simple_unregister_notifier);
+
 static int panel_simple_regulator_enable(struct panel_simple *p)
 {
 	int err;
@@ -499,6 +530,9 @@ static int panel_simple_regulator_enable(struct panel_simple *p)
 			return err;
 	}
 
+    pr_err("%s, %d", __func__, __LINE__);
+    panel_simple_send_notify(PANEL_SIMPLE_POWER_ON, NULL);
+
 	return 0;
 }
 
@@ -506,6 +540,9 @@ static int panel_simple_regulator_disable(struct panel_simple *p)
 {
 	int err;
 
+    pr_err("%s, %d", __func__, __LINE__);
+    panel_simple_send_notify(PANEL_SIMPLE_POWER_OFF, NULL);
+
 	if (p->power_invert) {
 		if (!regulator_is_enabled(p->supply)) {
 			err = regulator_enable(p->supply);
diff --git a/drivers/input/touchscreen/goodix.c b/drivers/input/touchscreen/goodix.c
index 111111111111..222222222222 100644
--- a/drivers/input/touchscreen/goodix.c
+++ b/drivers/input/touchscreen/goodix.c
@@ -23,6 +23,9 @@
 #include <linux/acpi.h>
 #include <linux/of.h>
 #include <asm/unaligned.h>
+#include <linux/init.h>
+#include <drm/drm_panel.h>
+
 #include "goodix.h"
 
 #define GOODIX_GPIO_INT_NAME		"irq"
@@ -58,6 +61,12 @@ struct goodix_chip_id {
 	const struct goodix_chip_data *data;
 };
 
+extern int panel_simple_register_notifier(struct notifier_block *nb);
+extern int panel_simple_unregister_notifier(struct notifier_block *nb);
+
+static int panel_notify_callback(struct notifier_block *nb,
+                               unsigned long action, void *data);
+
 static int goodix_check_cfg_8(struct goodix_ts_data *ts,
 			      const u8 *cfg, int len);
 static int goodix_check_cfg_16(struct goodix_ts_data *ts,
@@ -1389,6 +1398,15 @@ static int goodix_ts_probe(struct i2c_client *client,
 		return error;
 
 	ts->chip = goodix_get_chip_data(ts->id);
+    ts->panel_on = 1;
+
+    pr_err("kickpi %s, %d", __func__, __LINE__);
+    ts->nb.notifier_call = panel_notify_callback;
+    error = panel_simple_register_notifier(&ts->nb);
+    if (error) {
+        pr_err("kickpi %s, %d", __func__, __LINE__);
+		dev_err(&client->dev, "Failed to register panel simple notifier : %d\n", error);
+    }
 
 	if (ts->load_cfg_from_disk) {
 		/* update device config */
@@ -1426,6 +1444,8 @@ static void goodix_ts_remove(struct i2c_client *client)
 {
 	struct goodix_ts_data *ts = i2c_get_clientdata(client);
 
+    panel_simple_unregister_notifier(&ts->nb);
+
 	if (ts->load_cfg_from_disk)
 		wait_for_completion(&ts->firmware_loading_complete);
 }
@@ -1526,7 +1546,40 @@ static int __maybe_unused goodix_resume(struct device *dev)
 	return 0;
 }
 
-static SIMPLE_DEV_PM_OPS(goodix_pm_ops, goodix_suspend, goodix_resume);
+//static SIMPLE_DEV_PM_OPS(goodix_pm_ops, goodix_suspend, goodix_resume);
+
+static int panel_notify_callback(struct notifier_block *nb,
+                               unsigned long action, void *data)
+{
+    struct goodix_ts_data *ts = container_of(nb, struct goodix_ts_data, nb);
+    struct i2c_client *client = ts->client;
+
+    struct panel_simple_notify_data *pdata = data;
+    pr_err("kickpi %s, %d", __func__, __LINE__);
+    switch (pdata->power_state) {
+        case PANEL_SIMPLE_POWER_ON:
+            if (ts->panel_on != 1) {
+                pr_err("kickpi %s, %d", __func__, __LINE__);
+                dev_err(&client->dev, "need resume after power on \n");
+                goodix_resume(&client->dev);
+                ts->panel_on = 1;
+            }
+            break;
+        case PANEL_SIMPLE_POWER_OFF:
+            if (ts->panel_on != 0) {
+                pr_err("kickpi %s, %d", __func__, __LINE__);
+                dev_err(&client->dev, "need suspend before power off \n");
+                goodix_suspend(&client->dev);
+                ts->panel_on = 0;
+            }
+            break;
+        default:
+            pr_err("kickpi %s, %d", __func__, __LINE__);
+            dev_err(&client->dev, " down kown state %d \n", pdata->power_state);
+            break;
+    }
+    return NOTIFY_DONE;
+}
 
 static const struct i2c_device_id goodix_ts_id[] = {
 	{ "GDIX1001:00", 0 },
@@ -1572,7 +1625,7 @@ static struct i2c_driver goodix_ts_driver = {
 		.name = "Goodix-TS",
 		.acpi_match_table = ACPI_PTR(goodix_acpi_match),
 		.of_match_table = of_match_ptr(goodix_of_match),
-		.pm = &goodix_pm_ops,
+		// .pm = &goodix_pm_ops,
 	},
 };
 module_i2c_driver(goodix_ts_driver);
diff --git a/drivers/input/touchscreen/goodix.h b/drivers/input/touchscreen/goodix.h
index 111111111111..222222222222 100644
--- a/drivers/input/touchscreen/goodix.h
+++ b/drivers/input/touchscreen/goodix.h
@@ -8,6 +8,7 @@
 #include <linux/input/mt.h>
 #include <linux/input/touchscreen.h>
 #include <linux/regulator/consumer.h>
+#include <linux/notifier.h>
 
 /* Register defines */
 #define GOODIX_REG_MISCTL_DSP_CTL		0x4010
@@ -104,6 +105,8 @@ struct goodix_ts_data {
 	u8 main_clk[GOODIX_MAIN_CLK_LEN];
 	int bak_ref_len;
 	u8 *bak_ref;
+    struct notifier_block nb;
+    int panel_on;
 };
 
 int goodix_i2c_read(struct i2c_client *client, u16 reg, u8 *buf, int len);
diff --git a/include/drm/drm_panel.h b/include/drm/drm_panel.h
index 111111111111..222222222222 100644
--- a/include/drm/drm_panel.h
+++ b/include/drm/drm_panel.h
@@ -28,6 +28,19 @@
 #include <linux/errno.h>
 #include <linux/list.h>
 
+enum {
+    PANEL_SIMPLE_POWER_ON = 0,
+    PANEL_SIMPLE_POWER_OFF,
+};
+
+struct panel_simple_notify_data {
+    int power_state;
+    void *private_data;
+};
+
+int panel_simple_register_notifier(struct notifier_block *nb);
+int panel_simple_unregister_notifier(struct notifier_block *nb);
+
 struct backlight_device;
 struct dentry;
 struct device_node;
-- 
Armbian

