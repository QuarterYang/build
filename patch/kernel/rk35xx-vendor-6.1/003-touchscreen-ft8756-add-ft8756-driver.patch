+        fts_ex_mode_switch(MODE_GLOVE, ENABLE);
+    } else if (FTS_SYSFS_ECHO_OFF(buf)) {
+        FTS_DEBUG("exit glove mode");
+        ts_data->glove_mode = DISABLE;
+        fts_ex_mode_switch(MODE_GLOVE, DISABLE);
+    }
+    mutex_unlock(&ts_data->input_dev->mutex);
+    return count;
