+*****************************************************************************/
+enum _ex_mode {
+    MODE_GLOVE = 0,
+    MODE_COVER,
+    MODE_CHARGER,
+    MODE_EARPHONE,
+    MODE_EDGEPALM
+};
+
+/*****************************************************************************
+* 4.Static variables
